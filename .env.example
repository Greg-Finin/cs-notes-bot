# Slack — both required for Socket Mode
# Bot token: starts with xoxb-  (OAuth & Permissions → Bot User OAuth Token)
SLACK_BOT_TOKEN=

# App token: starts with xapp-  (Basic Information → App-Level Tokens, scope: connections:write)
SLACK_APP_TOKEN=

# Anthropic — required for /csnote ask
ANTHROPIC_API_KEY=

# SQLite file location. Defaults to ./csnotes.db
CSNOTES_DB_PATH=csnotes.db
